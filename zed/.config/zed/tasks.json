  {
    "label": "format dune file",
    "command": "dune format $ZED_FILE",
    // "command": "dune format $ZED_FILE_NAME > $ZED_FILE_NAME.formatted",
    // "command": "bash -c '[[ \"$ZED_STEM\" == \"dune\" ]] && eval $(opam env) && dune format $ZED_FILE_NAME > $ZED_FILE_NAME.formatted'",
    "tags": ["ocaml", "format", "dune"],
    "use_new_terminal": true,
    // "reveal": "no_focus",
