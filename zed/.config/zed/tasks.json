// Static tasks configuration.
//
// Example:
[
  {
    "label": "LazyGit",
    "command": "lazygit -p $ZED_WORKTREE_ROOT",
    "args": [],
    "env": {},
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "shell": {
      "program": "dash",
    },
  },
  {
    "label": "tmux send-keys template",
    "command": "tmux send-keys -t 'main:0.0' '$ZED_FILE' Enter",
    "tags": ["tmux"],
    "hide": "always",
    "reveal": "never",
    "use_new_terminal": true,
    "shell": {
      "program": "dash",
    },
  },
  // <Rust>
  {
    "label": "cargo insta lib test - accept",
    // "command": "cargo insta test --accept --lib -- $ZED_STEM",
    // If stem is "mod", use the parent directory name as the filter
    "command": "bash -c '[[ \"$ZED_STEM\" == \"mod\" ]] && cargo insta test --accept --lib -- $ZED_RELATIVE_DIR || cargo insta test --accept --lib -- $ZED_STEM'",
    "tags": ["rust", "test", "snapshot-testing"],
    "reveal": "always",
    "hide": "on_success",
    "shell": {
      "program": "dash",
    },
  },
  {
    "label": "cargo insta lib test - review",
    "command": "cargo insta test --review --lib -- $ZED_STEM --show-output",
    "tags": ["rust", "test", "snapshot-testing"],
    "use_new_terminal": true,
    "shell": {
      "program": "dash",
    },
  },
  {
    "label": "cargo lib test",
    "command": "cargo test --lib $ZED_STEM",
    "tags": ["rust", "test"],
    "hide": "on_success",
    "shell": {
      "program": "dash",
    },
  },
  // </Rust>
  // <OCaml>
  {
